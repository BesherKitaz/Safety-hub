// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================
// Models
// =====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole @default(STUDENT)
  firstName String
  lastName  String
  passwordHash String
  issuedCertifications   Certification[] @relation("IssuedCertifications")
  receivedCertifications Certification[] @relation("ReceivedCertifications")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lab {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  tools       Tool[]
  certifications Certification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
}

model Tool {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  labId       String
  lab         Lab   @relation(fields: [labId], references: [id])
  
  certifications Certification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model Certification {
  id String @id @default(cuid())

  issuedToId String
  issuedTo   User   @relation("ReceivedCertifications", fields: [issuedToId], references: [id])

  issuedById String
  issuedBy   User   @relation("IssuedCertifications", fields: [issuedById], references: [id])

  labId String
  lab   Lab @relation(fields: [labId], references: [id])
  
  toolId String?
  tool   Tool? @relation(fields: [toolId], references: [id])

  notes String?

  issuedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([issuedToId, labId, toolId])
  @@index([labId])
  @@index([issuedToId, labId])
}



// =====================
// Enums
// =====================

enum UserRole {
  ADMIN
  STAFF
  SUPERVISOR
  MENTOR
  STUDENT
}

