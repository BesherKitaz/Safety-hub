// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================
// Models
// =====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole @default(STUDENT)
  firstName String
  lastName  String
  isUserAgreementComplete Boolean @default(false)
  userAgreementSource String?
  passwordHash String


  issuedCertifications   Certification[] @relation("IssuedCertifications")
  receivedCertifications Certification[] @relation("ReceivedCertifications")
  CertificationsRevoked Certification[] @relation("CertificationsRevoked")


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lab {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  tools       Tool[]
  trainingNodes TrainingNode[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
}

model Tool {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  labId       String
  lab         Lab   @relation(fields: [labId], references: [id])
  
  trainingNode TrainingNode?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model Certification {
  id String @id @default(cuid())

  issuedToId String
  issuedTo   User   @relation("ReceivedCertifications", fields: [issuedToId], references: [id])

  issuedById String
  issuedBy   User   @relation("IssuedCertifications", fields: [issuedById], references: [id])

  
  trainingNodeId String
  trainingNode   TrainingNode @relation(fields: [trainingNodeId], references: [id])

  notes String?
  

  status CertificationStatus @default(ACTIVE)
  level Int @default(1)

  revokedAt DateTime?
  revokedById String?
  revokedBy User? @relation("CertificationsRevoked", fields: [revokedById], references: [id])
  revokeReason String?

  issuedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiryDate DateTime? 


  @@unique([issuedToId, trainingNodeId, level])
  @@index([issuedToId])
  @@index([trainingNodeId])
}


model TrainingNode {
  id   String @id @default(cuid())
  name String
  type TrainingNodeType

  labId String
  lab   Lab   @relation(fields: [labId], references: [id])

  toolId String? @unique
  tool   Tool?   @relation(fields: [toolId], references: [id])


  parentEdges TrainingEdge[] @relation("ChildEdges")
  childEdges  TrainingEdge[] @relation("ParentEdges")

  certifications Certification[]
}


model TrainingEdge {
  id   String @id @default(cuid())

  parentId String
  parent   TrainingNode @relation("ParentEdges", fields: [parentId], references: [id])

  childId String
  child   TrainingNode @relation("ChildEdges", fields: [childId], references: [id])

  @@unique([parentId, childId])
}



// =====================
// Enums
// =====================

enum TrainingNodeType {
  GENERAL
  LAB
  TOOL
}

enum UserRole {
  ADMIN
  STAFF
  SUPERVISOR
  MENTOR
  STUDENT
}

enum CertificationStatus {
  ACTIVE
  DEACTIVATED
  EXPIRED
  REVOKED
}

