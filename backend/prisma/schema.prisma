// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================
// Models
// =====================


model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole @default(STUDENT)
  firstName String
  lastName  String
  isUserAgreementComplete Boolean @default(false)
  userAgreementSource String?
  passwordHash String


  issuedCertifications   Certification[] @relation("IssuedCertifications")
  receivedCertifications Certification[] @relation("ReceivedCertifications")
  certificationsUpdated CertificationHistory[] @relation("CertificationHistoryChangedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Lab {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isActive Boolean @default(true)

  tools       Tool[]
  trainingNodes TrainingNode[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
}


model Tool {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  labId       String
  lab         Lab   @relation(fields: [labId], references: [id])
  isActive Boolean @default(true)
  
  trainingNode TrainingNode?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Certification {
  id             String @id @default(cuid())

  trainingNodeId String
  trainingNode   TrainingNode @relation(fields: [trainingNodeId], references: [id])

  notes          String?
  status         CertificationStatus @default(ACTIVE)
  level          Int @default(1)
  expiryDate     DateTime?

  issuedToId     String
  issuedTo       User @relation("ReceivedCertifications", fields: [issuedToId], references: [id])

  issuedById     String
  issuedBy       User @relation("IssuedCertifications", fields: [issuedById], references: [id])

  issuedAt       DateTime @default(now())

  history        CertificationHistory[] @relation("CertificationHistory")

  @@unique([issuedToId, trainingNodeId, level])
  @@index([issuedToId])
  @@index([trainingNodeId])
}

model CertificationHistory {
  id              String @id @default(cuid())

  certificationId String
  certification   Certification @relation("CertificationHistory", fields: [certificationId], references: [id])

  // snapshot BEFORE action
  levelBefore     Int
  statusBefore    CertificationStatus
  expiryDateBefore DateTime?
  notesBefore     String?

  // snapshot AFTER action
  levelAfter      Int
  statusAfter     CertificationStatus
  expiryDateAfter DateTime?
  notesAfter      String?

  trainingNodeIdBefore String
  trainingNodeBefore   TrainingNode @relation("TrainingNodeCertificationHistory", fields: [trainingNodeIdBefore], references: [id])
  trainingNodeIdAfter  String
  trainingNodeAfter    TrainingNode @relation("TrainingNodeCertificationHistoryAfter", fields: [trainingNodeIdAfter], references: [id])

  action          CertificationHistoryAction

  changedById     String
  changedBy       User @relation("CertificationHistoryChangedBy", fields: [changedById], references: [id])

  changedAt       DateTime @default(now())
  reason          String?

  @@index([certificationId])
  @@index([changedById])
}


model TrainingNode {
  id   String @id @default(cuid())
  name String
  type TrainingNodeType

  labId String
  lab   Lab   @relation(fields: [labId], references: [id])
  isActive Boolean @default(true)

  toolId String? @unique
  tool   Tool?   @relation(fields: [toolId], references: [id])


  parentEdges TrainingEdge[] @relation("ChildEdges")
  childEdges  TrainingEdge[] @relation("ParentEdges")

  certifications Certification[]
  certificationHistory CertificationHistory[] @relation("TrainingNodeCertificationHistory")
  certificationHistoryAfter CertificationHistory[] @relation("TrainingNodeCertificationHistoryAfter")
}


model TrainingEdge {
  id   String @id @default(cuid())

  parentId String
  parent   TrainingNode @relation("ParentEdges", fields: [parentId], references: [id])

  childId String
  child   TrainingNode @relation("ChildEdges", fields: [childId], references: [id])

  @@unique([parentId, childId])
}



// =====================
// Enums
// =====================

enum TrainingNodeType {
  GENERAL
  LAB
  TOOL
}

enum UserRole {
  ADMIN
  STAFF
  SUPERVISOR
  MENTOR
  STUDENT
}

enum CertificationStatus {
  ACTIVE
  DEACTIVATED
  EXPIRED
  REVOKED
}

enum CertificationHistoryAction {
  CREATED
  UPDATED
  REVOKED
  REACTIVATED
  EXPIRED
  DEACTIVATED
}


